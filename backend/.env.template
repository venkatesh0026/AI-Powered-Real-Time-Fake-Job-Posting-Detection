# Backend environment variables
# Copy this file to .env and fill in your values.

SECRET_KEY=your-secret-key-here
# Generate a secure random string for production (e.g. openssl rand -hex 32)

SUPABASE_URL=https://your-project.supabase.co
# Copy the "Project URL" from your Supabase project settings

SUPABASE_KEY=your-supabase-anon-key
# Copy the "Anon" (public) key from Supabase project API settings

# Optional: BERT model directory. Leave unset to use backend/ml/bert_model_output
# MODEL_PATH=ml/bert_model_output
